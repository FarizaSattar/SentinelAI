# =========================
# Azure OpenAI Configuration
# =========================
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =========================
# Microsoft Sentinel Config
# =========================
SENTINEL_WORKSPACE_ID=your_log_analytics_workspace_id
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id
RESOURCE_GROUP=your_resource_group_name

# =========================
# Logic App (Playbook)
# =========================
LOGIC_APP_URL=https://your-logic-app-url

# =========================
# Security / App Settings
# =========================
ENVIRONMENT=development
LOG_LEVEL=info
ENABLE_AI_ENRICHMENT=true

# =========================
# Optional Integrations
# =========================
TEAMS_WEBHOOK_URL=https://your-teams-webhook
SLACK_WEBHOOK_URL=https://your-slack-webhook
