{
  "name": "Run-AI-Incident-Playbook",
  "properties": {
    "displayName": "Run AI Incident Enrichment Playbook",
    "enabled": true,
    "order": 1,
    "conditions": [
      {
        "property": "IncidentStatus",
        "operator": "NotEquals",
        "value": "Closed"
      }
    ],
    "actions": [
      {
        "actionType": "RunPlaybook",
        "workflowId": "/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RESOURCE_GROUP>/providers/Microsoft.Logic/workflows/chatgpt-incident-playbook"
      }
    ]
  }
}
